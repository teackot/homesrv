<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>Custom</short>
  <service name="dhcpv6-client"/>
  <service name="ssh"/>
  <rule family="ipv4">
    <forward-port port="80" protocol="tcp" to-port="8080"/>
  </rule>
  <rule family="ipv4">
    <forward-port port="443" protocol="tcp" to-port="8443"/>
  </rule>
  <forward/>
</zone>
